        "imageUrl"
      ]
    }
  },
  "auth": {
    "providers": [
      "anonymous"
    ]
  },
  "firestore": {
    "/doors/{doorId}": {
      "schema": "Door",
      "description": "مجموعة الأبواب في الكتالوج"
    }
  }
}